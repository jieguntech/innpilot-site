---
import "../styles/global.css";

const navItems = ["Platform", "Front Desk", "Payments", "Pricing"];
const trustedBy = ["Harbourview", "The Dunes", "Marlowe Inn", "Cedar & Pine", "Soleil Suites"];

const automationCards = [
  {
    number: "01",
    title: "Self check-in",
    copy: "Guests check in from their phone and get a secure door code, with no queue and no front-desk staffing at 2am.",
    badge: "Contactless",
    tone: "bg-violet/10 text-violet"
  },
  {
    number: "02",
    title: "AI customer service",
    copy: "Answers guest messages instantly across email, WhatsApp and chat, in any language, day or night.",
    badge: "24/7 replies",
    tone: "bg-mint/10 text-[#1E8F52]"
  },
  {
    number: "03",
    title: "AI phone assistant",
    copy: "A natural-sounding voice agent takes calls, quotes rates and books rooms so the phone never rings out.",
    badge: "Never miss a call",
    tone: "bg-coral/10 text-[#C24632]"
  },
  {
    number: "04",
    title: "Booking management",
    copy: "AI syncs every channel, prevents double bookings and suggests smart rates as demand shifts.",
    badge: "Smart pricing",
    tone: "bg-lime/15 text-lime",
    featured: true
  }
];

const features = [
  {
    number: "01",
    title: "Live reservation calendar",
    copy: "Drag-and-drop bookings, split stays and group blocks across every room type, updated the instant a channel confirms.",
    className: "lg:row-span-2",
    visual: true
  },
  {
    number: "02",
    title: "Payments built in",
    copy: "Take deposits, charge on checkout and reconcile automatically, with no third-party terminal required.",
    accent: "bg-lime text-ink"
  },
  {
    number: "03",
    title: "Housekeeping board",
    copy: "Rooms flip from dirty to ready in real time, so your team always knows what is next.",
    accent: "bg-coral text-white"
  },
  {
    number: "04",
    title: "Every channel, one inbox",
    copy: "Booking.com, Airbnb, Expedia and your own website sync two ways, with no double bookings and no spreadsheets.",
    className: "lg:col-span-2",
    accent: "bg-mint text-white",
    channels: ["Booking.com", "Airbnb", "Expedia", "Stripe"]
  }
];

const stats = [
  ["3.5h", "saved on admin every day"],
  ["+18%", "average lift in direct bookings"],
  ["7 min", "to go live, not weeks"]
];

const rooms = [
  { name: "Room 101", guest: "J. Okafor", start: 2, span: 3, color: "bg-violet" },
  { name: "Room 102", guest: "Nguyen", start: 5, span: 3, color: "bg-lime text-ink" },
  { name: "Suite 201", guest: "Rossi", start: 2, span: 2, color: "bg-coral" },
  { name: "Suite 202", guest: "Patel", start: 6, span: 2, color: "bg-violet" },
  { name: "Room 103", guest: "Andersen", start: 4, span: 4, color: "bg-mint" }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="InnPilot is an AI-powered PMS for hotels and motels, automating self check-in, guest service, phone calls, and booking management."
    />
    <title>InnPilot | AI-powered PMS for hotels and motels</title>
  </head>
  <body>
    <header class="container-page flex items-center justify-between py-5">
      <a href="/" class="flex items-center gap-2 font-display text-xl font-extrabold" aria-label="InnPilot home">
        <span class="flex size-9 items-center justify-center rounded-lg bg-violet text-sm font-extrabold text-white">IP</span>
        InnPilot
      </a>

      <nav class="hidden items-center gap-8 text-sm font-semibold text-muted lg:flex" aria-label="Main navigation">
        {navItems.map((item) => <a href={`#${item.toLowerCase().replaceAll(" ", "-")}`} class="hover:text-ink">{item}</a>)}
      </nav>

      <div class="flex items-center gap-3">
        <a href="#login" class="hidden text-sm font-bold text-muted hover:text-ink sm:inline-flex">Log in</a>
        <a href="#demo" class="btn btn-primary">Book a demo</a>
      </div>
    </header>

    <main>
      <section class="container-page grid min-h-[calc(100svh-84px)] items-center gap-10 pb-12 pt-8 lg:grid-cols-[0.94fr_1.06fr] lg:pb-20 lg:pt-14">
        <div class="max-w-2xl">
          <p class="eyebrow bg-violet/10 text-violet">AI-powered PMS for hotels & motels</p>
          <h1 class="mt-6 font-display text-[clamp(3.1rem,8vw,5.9rem)] font-extrabold leading-[0.94] tracking-normal text-ink">
            Let AI run the busywork of your property.
          </h1>
          <p class="mt-7 max-w-xl text-lg leading-8 text-[#514C42] sm:text-xl">
            InnPilot is the AI-powered, all-in-one platform for self check-in, AI customer service, an AI phone assistant and booking management, automating repetitive work so your team can focus on guests.
          </p>

          <div class="mt-9 flex flex-wrap items-center gap-4">
            <a href="#trial" class="btn btn-primary px-7">Start free trial</a>
            <a href="#tour" class="btn btn-secondary gap-3">
              <span class="flex size-8 items-center justify-center rounded-full bg-ink text-[10px] text-white" aria-hidden="true">▶</span>
              Watch tour
            </a>
          </div>

          <div class="mt-8 flex flex-wrap items-center gap-x-7 gap-y-3 text-sm font-semibold text-muted">
            <span class="font-display text-base font-extrabold text-ink">4.9 on Capterra</span>
            <span>No card required</span>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -right-4 -top-4 hidden size-28 rotate-6 rounded-lg bg-lime shadow-soft sm:block"></div>
          <div class="relative overflow-hidden rounded-lg border border-ink/10 bg-white p-4 shadow-soft sm:p-6">
            <div class="mb-5 flex items-center justify-between gap-4">
              <div>
                <p class="text-xs font-bold uppercase text-muted">InnPilot · Reservations</p>
                <h2 class="font-display text-2xl font-extrabold">March 2026</h2>
              </div>
              <span class="rounded-full bg-lime px-4 py-2 text-sm font-extrabold text-ink">92% occupied</span>
            </div>

            <div class="grid grid-cols-[74px_repeat(7,minmax(38px,1fr))] gap-1.5 text-center text-xs font-bold text-muted">
              <span></span>
              {["12", "13", "14", "15", "16", "17", "18"].map((day) => <span>{day}</span>)}
            </div>

            <div class="mt-3 space-y-2">
              {
                rooms.map((room) => (
                  <div class="grid grid-cols-[74px_repeat(7,minmax(38px,1fr))] gap-1.5">
                    <span class="flex items-center text-[11px] font-extrabold text-muted">{room.name}</span>
                    {[1, 2, 3, 4, 5, 6, 7].map((day) => <span class="h-7 rounded-md bg-oat"></span>)}
                    <span
                      class={`row-start-1 flex h-7 items-center rounded-md px-2 text-[11px] font-extrabold text-white ${room.color}`}
                      style={`grid-column: ${room.start} / span ${room.span};`}
                    >
                      {room.guest}
                    </span>
                  </div>
                ))
              }
            </div>

            <div class="mt-5 grid gap-3 sm:grid-cols-2">
              <div class="rounded-lg bg-[#F6F4EE] p-4">
                <p class="text-xs font-bold text-muted">Arrivals today</p>
                <p class="font-display text-3xl font-extrabold">14</p>
              </div>
              <div class="rounded-lg bg-ink p-4 text-white">
                <p class="text-xs font-bold text-[#B9B3A6]">Revenue today</p>
                <p class="font-display text-3xl font-extrabold">$8.2k</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="container-page pb-16">
        <p class="text-center text-xs font-bold uppercase text-[#9A958A]">Trusted by 1,200+ independent properties</p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-4 opacity-70">
          {trustedBy.map((name) => <span class="font-display text-xl font-extrabold">{name}</span>)}
        </div>
      </section>

      <section id="platform" class="container-page py-14">
        <div class="mx-auto max-w-3xl text-center">
          <p class="eyebrow bg-violet/10 text-violet">One AI-powered platform</p>
          <h2 class="section-title mt-5">Four jobs, automated end to end.</h2>
          <p class="mt-4 text-lg leading-8 text-[#514C42]">
            InnPilot's AI handles the phones, the messages, the check-ins and the calendar around the clock, so nothing falls through the cracks.
          </p>
        </div>

        <div class="mt-11 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
          {
            automationCards.map((card) => (
              <article class={`card flex flex-col ${card.featured ? "bg-ink text-paper" : "bg-white"}`}>
                <span class={`icon-tile ${card.featured ? "bg-violet text-white" : card.tone}`}>{card.number}</span>
                <h3 class="mt-5 font-display text-xl font-bold">{card.title}</h3>
                <p class={`mt-3 text-[15px] leading-7 ${card.featured ? "text-[#B9B3A6]" : "text-[#514C42]"}`}>{card.copy}</p>
                <span class={`mt-5 w-fit rounded-full px-3 py-1.5 text-xs font-extrabold ${card.featured ? "bg-lime/15 text-lime" : card.tone}`}>
                  {card.badge}
                </span>
              </article>
            ))
          }
        </div>
      </section>

      <section id="front-desk" class="bg-ink py-20 text-paper sm:py-24">
        <div class="container-page">
          <div class="max-w-2xl">
            <p class="eyebrow bg-lime/15 text-lime">The platform</p>
            <h2 class="section-title mt-5 text-paper">Everything the front desk needs, nothing it does not.</h2>
          </div>

          <div class="mt-12 grid gap-5 lg:grid-cols-3">
            {
              features.map((feature) => (
                <article class={`feature-card ${feature.className ?? ""}`}>
                  <span class={`icon-tile ${feature.accent ?? "bg-violet text-white"}`}>{feature.number}</span>
                  <h3 class="mt-5 font-display text-2xl font-bold">{feature.title}</h3>
                  <p class="mt-3 text-[15px] leading-7 text-[#B9B3A6]">{feature.copy}</p>

                  {feature.visual && (
                    <div class="mt-8 rounded-lg bg-[#17140E] p-4">
                      <div class="mb-2 flex gap-1.5">
                        <span class="h-4 flex-[2] rounded bg-violet"></span>
                        <span class="h-4 flex-1 rounded bg-[#332D20]"></span>
                      </div>
                      <div class="mb-2 flex gap-1.5">
                        <span class="h-4 flex-1 rounded bg-[#332D20]"></span>
                        <span class="h-4 flex-[2] rounded bg-lime"></span>
                      </div>
                      <div class="flex gap-1.5">
                        <span class="h-4 flex-[3] rounded bg-coral"></span>
                      </div>
                    </div>
                  )}

                  {feature.channels && (
                    <div class="mt-7 flex flex-wrap gap-2">
                      {feature.channels.map((channel) => (
                        <span class="rounded-md bg-[#17140E] px-3 py-2 text-sm font-bold">{channel}</span>
                      ))}
                    </div>
                  )}
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="payments" class="container-page py-16 sm:py-20">
        <div class="grid gap-6 md:grid-cols-3">
          {
            stats.map(([value, label], index) => (
              <div class={`p-5 text-center ${index === 1 ? "md:border-x md:border-ink/10" : ""}`}>
                <p class={`font-display text-5xl font-extrabold ${index === 1 ? "text-ink" : "text-violet"}`}>{value}</p>
                <p class="mt-2 text-sm font-semibold text-[#514C42]">{label}</p>
              </div>
            ))
          }
        </div>
      </section>

      <section id="pricing" class="container-page pb-20">
        <div class="relative overflow-hidden rounded-lg bg-violet px-6 py-16 text-center text-white shadow-glow sm:px-12">
          <div class="absolute right-0 top-0 h-24 w-32 bg-lime/90"></div>
          <div class="absolute bottom-0 left-0 h-20 w-28 bg-ink/45"></div>
          <div class="relative mx-auto max-w-2xl">
            <h2 class="font-display text-4xl font-extrabold leading-[1.06] sm:text-5xl">Give your front desk its best day yet.</h2>
            <p class="mx-auto mt-5 max-w-xl text-lg leading-8 text-white/90">
              Start a free 14-day trial. No card, no lock-in, and a real person to help you set up.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-4">
              <a id="trial" href="mailto:hello@innpilot.ai" class="btn bg-white px-7 text-ink hover:-translate-y-0.5">Start free trial</a>
              <a id="demo" href="mailto:sales@innpilot.ai" class="btn border border-white/30 bg-white/15 px-7 text-white hover:-translate-y-0.5 hover:bg-white/20">Talk to sales</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-ink/10">
      <div class="container-page flex flex-wrap items-center justify-between gap-5 py-8">
        <a href="/" class="flex items-center gap-2 font-display text-lg font-extrabold">
          <span class="flex size-7 items-center justify-center rounded-md bg-violet text-xs text-white">IP</span>
          InnPilot
        </a>
        <nav class="flex flex-wrap gap-6 text-sm font-semibold text-muted" aria-label="Footer navigation">
          <a href="#platform">Platform</a>
          <a href="#pricing">Pricing</a>
          <a href="mailto:help@innpilot.ai">Help centre</a>
          <a href="mailto:hello@innpilot.ai">Contact</a>
        </nav>
        <p class="text-sm text-[#9A958A]">© 2026 InnPilot. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
